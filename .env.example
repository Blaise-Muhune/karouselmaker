# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# App URL for password reset and OAuth callback (e.g. https://yourapp.com). Defaults to http://localhost:3000
# Add to Supabase: Authentication → URL Configuration → Redirect URLs:
#   - {NEXT_PUBLIC_APP_URL}/auth/callback
#   - {NEXT_PUBLIC_APP_URL}/reset-password
# NEXT_PUBLIC_APP_URL=
# Server-only; never expose to client
SUPABASE_SERVICE_ROLE_KEY=

# AI (server-only)
OPENAI_API_KEY=

# Optional: fallback when OpenAI image gen is rejected by safety (Replicate: Ideogram v3 then FLUX Schnell). Get token: https://replicate.com/account/api-tokens
# REPLICATE_API_TOKEN=
# Set to true to log Replicate output when no URL is found (for debugging)
# REPLICATE_DEBUG=true
#
# OpenAI slide/carousel image generation (server terminal): step log for i2i vs text-only, ref counts, API timings.
# Does not remove the existing full-prompt log; adds [openaiImageGenerate:debug] lines when enabled.
# IMAGE_GEN_DEBUG=1

# Optional: AI-suggested slide backgrounds
# Brave Search (primary): https://api-dashboard.search.brave.com/ — free tier: 2,000 queries/month
BRAVE_SEARCH_API_KEY=
# Unsplash (fallback): https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=
# Google Drive import: enable "Import from Drive" / "From Drive" for folder-based image import.
# Create OAuth 2.0 Client ID (Web) and enable Drive API + Picker API in Google Cloud Console.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=    # OAuth client ID (xxx.apps.googleusercontent.com)
NEXT_PUBLIC_GOOGLE_APP_ID=   # Project number (numeric) for Picker
NEXT_PUBLIC_GOOGLE_API_KEY=       # API key for Picker (Credentials → Create → API key)
# Debug: set to true to log image search flow (Brave/Unsplash) to console
# IMAGE_SEARCH_DEBUG=true

# Chromium export (Vercel): optional override if GitHub pack download times out.
# Default: https://github.com/Sparticuz/chromium/releases/download/v143.0.4/chromium-v143.0.4-pack.x64.tar
# You can host the pack on Vercel Blob or another CDN and set that URL here.
# CHROMIUM_REMOTE_EXEC_PATH=

# Contact form (server-only) — messages sent to CONTACT_EMAIL
# Resend free tier: onboarding@resend.dev can only send to your Resend account email.
# To send to any address: verify a domain at resend.com/domains, then set RESEND_FROM_EMAIL.
RESEND_API_KEY=
CONTACT_EMAIL=
RESEND_FROM_EMAIL=

# Stripe (server-only)
STRIPE_SECRET_KEY=
STRIPE_SUBSCRIPTION_STARTER_PRICE_ID=
STRIPE_SUBSCRIPTION_PRO_PRICE_ID=
STRIPE_SUBSCRIPTION_STUDIO_PRICE_ID=
STRIPE_SUBSCRIPTION_STARTER_YEARLY_PRICE_ID=price_1TKJDzPtWUOWsGyOZ0VCNVOv
STRIPE_SUBSCRIPTION_PRO_YEARLY_PRICE_ID=price_1TKJFiPtWUOWsGyOGmcEr1uf
STRIPE_SUBSCRIPTION_STUDIO_YEARLY_PRICE_ID=price_1TKJHjPtWUOWsGyOcpu2rgbV
STRIPE_WEBHOOK_SECRET=

# Image proxy for video export (server-only). Required for MP4 download when slides use external images (e.g. Unsplash, Brave). Set to any random string.
# IMAGE_PROXY_SECRET=

# Voiceover / TTS for video (server-only). Default: ElevenLabs. Get key: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
# Optional default voice (voice_id from https://api.elevenlabs.io/v1/voices). User can still pick voice in UI.
# ELEVENLABS_DEFAULT_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Post to social (server-only). See docs/POSTING_APIS.md. Only needed if you implement OAuth + publish.
# Facebook / Meta (same app can power Facebook + Instagram)
FACEBOOK_APP_ID=1123317456541988
FACEBOOK_APP_SECRET=dd879af1cded600bc3a5542a5122c153
INSTAGRAM_APP_ID=3082400665482515
INSTAGRAM_APP_SECRET=1ede423dd68013f9dbd2ba608920db10
# TikTok
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
# LinkedIn
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
# YouTube (Google Cloud OAuth 2.0 credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

